{
  "name": "@flowforge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p renderer/tsconfig.json --noEmit",
    "dev": "node scripts/dev.mjs",
    "start": "electron ."
  },
  "dependencies": {
    "@flowforge/agents": "workspace:*",
    "@flowforge/audit": "workspace:*",
    "@flowforge/core": "workspace:*",
    "@flowforge/identity": "workspace:*",
    "@flowforge/memory": "workspace:*",
    "@flowforge/packages": "workspace:*",
    "@flowforge/workflow": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^7.3.5"
  }
}
